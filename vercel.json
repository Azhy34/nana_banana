{
  "functions": {
    "api/animate.ts": { "maxDuration": 30 },
    "api/animate/poll.ts": { "maxDuration": 60 },
    "api/upscale.ts": { "maxDuration": 30 },
    "api/upscale/poll.ts": { "maxDuration": 60 }
  },
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}