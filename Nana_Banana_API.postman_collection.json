							"mode": "raw",
							"raw": "{\n  \"sessionId\": \"sess_test_123456\",\n  \"model\": \"gemini-3.1-flash-image\",\n  \"prompt\": \"A premium photograph of a cozy nursery with wild floral wallpaper, natural daylight, Canon EOS R5.\",\n  \"cost\": 0.0504,\n  \"duration\": 11.2,\n  \"status\": \"success\",\n  \"error\": null\n}"
